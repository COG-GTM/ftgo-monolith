# =============================================================================
# FTGO Platform - EditorConfig
# =============================================================================
# Consistent coding style across all IDEs and editors.
# See https://editorconfig.org for supported editors.
# =============================================================================

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Java source files
[*.java]
indent_size = 4
max_line_length = 120

# Groovy (Gradle build scripts, convention plugins)
[*.groovy]
indent_size = 4

# Gradle build files
[*.gradle]
indent_size = 4

# Gradle Kotlin DSL
[*.gradle.kts]
indent_size = 4

# XML files (Spring config, Checkstyle, PMD, SpotBugs)
[*.xml]
indent_size = 2

# YAML files (GitHub Actions, Docker Compose)
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Properties files
[*.properties]
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Dockerfiles
[Dockerfile*]
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab

# TOML (Gradle version catalog)
[*.toml]
indent_size = 4
