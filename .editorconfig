# FTGO Monolith - EditorConfig
# https://editorconfig.org
#
# Ensures consistent formatting across all editors and IDEs
# for the FTGO monolith and microservices migration project.

# Top-level EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java source files
[*.java]
indent_style = space
indent_size = 4
max_line_length = 150

# Gradle build files
[*.gradle]
indent_style = space
indent_size = 4

# Gradle properties
[*.properties]
indent_style = space
indent_size = 4

# Kotlin scripts (Gradle KTS)
[*.kts]
indent_style = space
indent_size = 4

# XML files (Spring configs, POM files, Checkstyle/PMD configs)
[*.xml]
indent_style = space
indent_size = 4

# YAML files (Docker Compose, Kubernetes manifests, CI configs)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown documentation
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 120

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4
end_of_line = lf

# Dockerfiles
[Dockerfile*]
indent_style = space
indent_size = 4

# SQL migration files
[*.sql]
indent_style = space
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab

# Git configuration files
[.gitattributes]
indent_style = space
indent_size = 4

# GitHub workflow files
[.github/**/*.yml]
indent_style = space
indent_size = 2
