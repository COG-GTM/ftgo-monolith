# EditorConfig: https://editorconfig.org
# Top-level EditorConfig file for FTGO project

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Java source files - Google Java Style
[*.java]
indent_style = space
indent_size = 4
max_line_length = 120

# Groovy files (Gradle build scripts, convention plugins)
[*.groovy]
indent_style = space
indent_size = 4
max_line_length = 120

# Gradle build files
[*.gradle]
indent_style = space
indent_size = 4

# Gradle properties
[*.properties]
indent_style = space
indent_size = 2

# YAML files (GitHub Actions, Docker Compose, etc.)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# XML files (Maven POM, Checkstyle config, SpotBugs config, etc.)
[*.xml]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Dockerfiles
[Dockerfile*]
indent_style = space
indent_size = 2

# SQL migration scripts
[*.sql]
indent_style = space
indent_size = 2

# TOML (Gradle version catalog)
[*.toml]
indent_style = space
indent_size = 2
