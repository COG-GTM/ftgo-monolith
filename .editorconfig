# =============================================================================
# FTGO Monolith - EditorConfig
# =============================================================================
# Consistent coding styles across different editors and IDEs.
# See: https://editorconfig.org
#
# This configuration enforces Google Java Format conventions for Java files
# and sensible defaults for other file types used in the project.
# =============================================================================

# Top-most EditorConfig file
root = true

# ---------------------------------------------------------------------------
# Default settings for all files
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Java source files - Google Java Format conventions
# ---------------------------------------------------------------------------
[*.java]
indent_style = space
indent_size = 2
max_line_length = 120
continuation_indent_size = 4

# ---------------------------------------------------------------------------
# Gradle build files (Groovy DSL)
# ---------------------------------------------------------------------------
[*.gradle]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Gradle Kotlin DSL
# ---------------------------------------------------------------------------
[*.gradle.kts]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Kotlin source files
# ---------------------------------------------------------------------------
[*.kt]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# XML files (Spring config, Maven POM, Checkstyle config, etc.)
# ---------------------------------------------------------------------------
[*.xml]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# YAML files (Docker Compose, GitHub Actions, Kubernetes, etc.)
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# JSON files
# ---------------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Properties files
# ---------------------------------------------------------------------------
[*.properties]
indent_style = space
indent_size = 4
charset = latin1

# ---------------------------------------------------------------------------
# Markdown files
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# ---------------------------------------------------------------------------
# Dockerfiles
# ---------------------------------------------------------------------------
[Dockerfile*]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Makefiles (require tabs)
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ---------------------------------------------------------------------------
# SQL files
# ---------------------------------------------------------------------------
[*.sql]
indent_style = space
indent_size = 2
