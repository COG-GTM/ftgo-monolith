{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Database Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"$service\"}",
          "legendFormat": "{{ job }} - active"
        }
      ]
    },
    {
      "title": "Idle Database Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_idle{job=~\"$service\"}",
          "legendFormat": "{{ job }} - idle"
        }
      ]
    },
    {
      "title": "Connection Pool Utilization (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"$service\"} / hikaricp_connections_max{job=~\"$service\"}",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "Max Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_max{job=~\"$service\"}",
          "legendFormat": "{{ job }} - max"
        },
        {
          "expr": "hikaricp_connections_active{job=~\"$service\"}",
          "legendFormat": "{{ job }} - active"
        }
      ]
    },
    {
      "title": "Pending Connection Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_pending{job=~\"$service\"}",
          "legendFormat": "{{ job }} - pending"
        }
      ]
    },
    {
      "title": "Connection Acquisition Time (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=~\"$service\"}[5m]) / rate(hikaricp_connections_acquire_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "Connection Creation Time (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_creation_seconds_sum{job=~\"$service\"}[5m]) / rate(hikaricp_connections_creation_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ftgo", "database", "hikaricp"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(hikaricp_connections_active, job)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(hikaricp_connections_active, job)" },
        "refresh": 2,
        "type": "query"
      },
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "FTGO - Database Connection Pool Metrics",
  "uid": "ftgo-db-pool-metrics",
  "version": 1
}
