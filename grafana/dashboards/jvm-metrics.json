{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"$service\"}",
          "legendFormat": "{{ job }} - {{ id }}"
        }
      ]
    },
    {
      "title": "JVM Heap Memory Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\", job=~\"$service\"}",
          "legendFormat": "{{ job }} - {{ id }}"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"$service\"}",
          "legendFormat": "{{ job }} - {{ id }} (used)"
        }
      ]
    },
    {
      "title": "JVM Non-Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\", job=~\"$service\"}",
          "legendFormat": "{{ job }} - {{ id }}"
        }
      ]
    },
    {
      "title": "GC Pause Duration (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"$service\"}[5m]) / rate(jvm_gc_pause_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }} - {{ cause }}"
        }
      ]
    },
    {
      "title": "GC Pause Count Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }} - {{ action }}"
        }
      ]
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"$service\"}",
          "legendFormat": "{{ job }} - live"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"$service\"}",
          "legendFormat": "{{ job }} - daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{job=~\"$service\"}",
          "legendFormat": "{{ job }} - peak"
        }
      ]
    },
    {
      "title": "Classes Loaded",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{job=~\"$service\"}",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "System CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "system_cpu_usage{job=~\"$service\"}",
          "legendFormat": "{{ job }} - system"
        },
        {
          "expr": "process_cpu_usage{job=~\"$service\"}",
          "legendFormat": "{{ job }} - process"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ftgo", "jvm", "infrastructure"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(jvm_memory_used_bytes, job)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(jvm_memory_used_bytes, job)" },
        "refresh": 2,
        "type": "query"
      },
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "FTGO - JVM Metrics",
  "uid": "ftgo-jvm-metrics",
  "version": 1
}
