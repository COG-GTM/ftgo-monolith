{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FTGO JVM Metrics - Memory, GC, Threads, and Class Loading",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "JVM Memory",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"}", "legendFormat": "{{ job }} - {{ id }}", "refId": "A" }
      ],
      "title": "Heap Memory Used",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"}", "legendFormat": "{{ job }} max - {{ id }}", "refId": "A" },
        { "expr": "jvm_memory_committed_bytes{job=~\"$service\", area=\"heap\"}", "legendFormat": "{{ job }} committed - {{ id }}", "refId": "B" }
      ],
      "title": "Heap Memory Max & Committed",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"} / jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"}",
          "legendFormat": "{{ job }} - {{ id }}",
          "refId": "A"
        }
      ],
      "title": "Heap Memory Utilization (%)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"nonheap\"}", "legendFormat": "{{ job }} - {{ id }}", "refId": "A" }
      ],
      "title": "Non-Heap Memory Used",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 201,
      "title": "Garbage Collection",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }} - {{ action }} {{ cause }}",
          "refId": "A"
        }
      ],
      "title": "GC Pause Duration Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }} - {{ action }} {{ cause }}",
          "refId": "A"
        }
      ],
      "title": "GC Pause Count Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 202,
      "title": "Threads",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=~\"$service\"}", "legendFormat": "{{ job }} live", "refId": "A" },
        { "expr": "jvm_threads_daemon_threads{job=~\"$service\"}", "legendFormat": "{{ job }} daemon", "refId": "B" },
        { "expr": "jvm_threads_peak_threads{job=~\"$service\"}", "legendFormat": "{{ job }} peak", "refId": "C" }
      ],
      "title": "Thread Count",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_threads_states_threads{job=~\"$service\"}", "legendFormat": "{{ job }} - {{ state }}", "refId": "A" }
      ],
      "title": "Thread States",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 203,
      "title": "Class Loading & CPU",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_classes_loaded_classes{job=~\"$service\"}", "legendFormat": "{{ job }} loaded", "refId": "A" }
      ],
      "title": "Loaded Classes",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "system_cpu_usage{job=~\"$service\"}", "legendFormat": "{{ job }} system", "refId": "A" },
        { "expr": "process_cpu_usage{job=~\"$service\"}", "legendFormat": "{{ job }} process", "refId": "B" }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["ftgo", "jvm", "performance"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(jvm_memory_used_bytes, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "query": "label_values(jvm_memory_used_bytes, job)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FTGO - JVM Metrics",
  "uid": "ftgo-jvm-metrics",
  "version": 1
}
