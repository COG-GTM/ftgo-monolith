<?xml version="1.0" encoding="UTF-8"?>
<!--
  FTGO Platform - SpotBugs Exclusion Filter
  Excludes false positives and legacy code from SpotBugs analysis.
  Applied via ftgo.code-quality-conventions Gradle plugin.
-->
<FindBugsFilter>
    <!-- Exclude generated code -->
    <Match>
        <Source name="~.*[\\/]generated[\\/].*"/>
    </Match>

    <!-- Exclude test code from certain checks -->
    <Match>
        <Class name="~.*Test$"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    <Match>
        <Class name="~.*Tests$"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>

    <!-- Suppress serialization warnings on JPA entities (common false positive) -->
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
    </Match>

    <!-- Suppress EI_EXPOSE_REP for DTOs and domain objects (intentional design) -->
    <Match>
        <Or>
            <Class name="~.*Dto$"/>
            <Class name="~.*DTO$"/>
            <Class name="~.*Request$"/>
            <Class name="~.*Response$"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Or>
            <Class name="~.*Dto$"/>
            <Class name="~.*DTO$"/>
            <Class name="~.*Request$"/>
            <Class name="~.*Response$"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Suppress MS_SHOULD_BE_FINAL for Spring-managed beans -->
    <Match>
        <Bug pattern="MS_SHOULD_BE_FINAL"/>
    </Match>
</FindBugsFilter>
