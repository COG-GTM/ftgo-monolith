<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="ftgo-application"/>
    <springProperty scope="context" name="logLevel" source="logging.level.root" defaultValue="INFO"/>

    <!-- Register the sensitive data masking converter -->
    <conversionRule conversionWord="maskedMsg"
                    converterClass="net.chrisrichardson.ftgo.logging.SensitiveDataMaskingConverter"/>

    <!-- ===================================================================
         Console appender: human-readable for local development.
         Includes traceId/spanId for correlation with distributed tracing.
         Uses maskedMsg to prevent sensitive data from appearing in logs.
         =================================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-N/A}/%X{spanId:-N/A}] [%X{correlationId:-N/A}] %-5level %logger{36} - %maskedMsg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================================================================
         JSON console appender: structured output for EFK stack ingestion.
         Includes all MDC fields: correlationId, serviceName, traceId, spanId.
         =================================================================== -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>serviceName</includeMdcKeyName>
            <includeMdcKeyName>requestMethod</includeMdcKeyName>
            <includeMdcKeyName>requestUri</includeMdcKeyName>
            <includeMdcKeyName>clientIp</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <customFields>{"service":"${serviceName}"}</customFields>
            <timeZone>UTC</timeZone>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        </encoder>
    </appender>

    <!-- ===================================================================
         Async wrapper around JSON_CONSOLE for non-blocking logging in
         deployed environments (staging, prod, k8s).
         =================================================================== -->
    <appender name="ASYNC_JSON_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <neverBlock>true</neverBlock>
        <appender-ref ref="JSON_CONSOLE"/>
    </appender>

    <!-- ===================================================================
         Rolling file appender for local development.
         Uses human-readable pattern with daily rotation and size cap.
         =================================================================== -->
    <appender name="LOCAL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/${serviceName}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/${serviceName}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-N/A}/%X{spanId:-N/A}] [%X{correlationId:-N/A}] %-5level %logger{36} - %maskedMsg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================================================================
         JSON file appender for persistent log storage in deployed environments.
         Uses rolling policy with compression.
         =================================================================== -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/var/log/ftgo/${serviceName}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>/var/log/ftgo/${serviceName}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>serviceName</includeMdcKeyName>
            <includeMdcKeyName>requestMethod</includeMdcKeyName>
            <includeMdcKeyName>requestUri</includeMdcKeyName>
            <includeMdcKeyName>clientIp</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <customFields>{"service":"${serviceName}"}</customFields>
            <timeZone>UTC</timeZone>
        </encoder>
    </appender>

    <!-- ===================================================================
         Profile: local development (human-readable console + rolling file)
         =================================================================== -->
    <springProfile name="default,local,dev">
        <root level="${logLevel}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOCAL_FILE"/>
        </root>
    </springProfile>

    <!-- ===================================================================
         Profile: staging (async JSON console for non-blocking output)
         =================================================================== -->
    <springProfile name="staging">
        <root level="${logLevel}">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ===================================================================
         Profile: production / Kubernetes (async JSON console)
         =================================================================== -->
    <springProfile name="prod,k8s">
        <root level="${logLevel}">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ===================================================================
         Profile: file logging alongside console (deployed environments)
         =================================================================== -->
    <springProfile name="file">
        <root level="${logLevel}">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
        </root>
    </springProfile>

    <!-- ===================================================================
         Logger-level overrides: reduce noise from framework loggers
         =================================================================== -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.apache" level="WARN"/>
    <logger name="net.chrisrichardson.ftgo" level="DEBUG"/>

</configuration>
