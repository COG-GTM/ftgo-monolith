{
  "_comment": "Keycloak Realm Configuration Template for FTGO Platform",
  "_instructions": "Import this template into Keycloak Admin Console > Create Realm > Import. Update client secrets and redirect URIs before deploying to production.",
  "realm": "ftgo",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "roles": {
    "realm": [
      {
        "name": "ROLE_USER",
        "description": "Standard FTGO platform user"
      },
      {
        "name": "ROLE_ADMIN",
        "description": "FTGO platform administrator"
      },
      {
        "name": "ROLE_RESTAURANT_OWNER",
        "description": "Restaurant owner with menu and order management access"
      },
      {
        "name": "ROLE_COURIER",
        "description": "Delivery courier with assignment and tracking access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "ftgo-api-gateway",
      "name": "FTGO API Gateway",
      "description": "API Gateway client for authenticating inbound requests",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "CHANGE_ME_IN_PRODUCTION",
      "redirectUris": [
        "http://localhost:8080/*",
        "https://api.ftgo.example.com/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://app.ftgo.example.com"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "email",
        "profile",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access"
      ]
    },
    {
      "clientId": "ftgo-web-app",
      "name": "FTGO Web Application",
      "description": "Public SPA client for the FTGO web frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "https://app.ftgo.example.com/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://app.ftgo.example.com"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "email",
        "profile",
        "roles"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "description": "Maps realm roles into the JWT token",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "_comment": "Sample test user — remove in production",
      "username": "testuser",
      "enabled": true,
      "email": "testuser@ftgo.example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "changeme",
          "temporary": true
        }
      ],
      "realmRoles": [
        "ROLE_USER"
      ]
    }
  ]
}
