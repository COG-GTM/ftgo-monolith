{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FTGO Platform - Database Connection Pool Metrics (HikariCP)",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Connection Pool Usage",
      "description": "Active vs. idle vs. max connections per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Active"
        },
        {
          "expr": "hikaricp_connections_idle{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Idle"
        },
        {
          "expr": "hikaricp_connections_max{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Connection Pool Utilization (%)",
      "description": "Percentage of max connections in use. Alert threshold: 90%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * hikaricp_connections_active{job=~\"ftgo-.*\"} / hikaricp_connections_max{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Connection Acquisition Time",
      "description": "Time to acquire a connection from the pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=~\"ftgo-.*\"}[5m]) / rate(hikaricp_connections_acquire_seconds_count{job=~\"ftgo-.*\"}[5m])",
          "legendFormat": "{{ job }} - Avg Acquisition"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Connection Creation Time",
      "description": "Time to create new database connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_creation_seconds_sum{job=~\"ftgo-.*\"}[5m]) / rate(hikaricp_connections_creation_seconds_count{job=~\"ftgo-.*\"}[5m])",
          "legendFormat": "{{ job }} - Avg Creation"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Connection Usage Time",
      "description": "Time connections are in use before being returned to the pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_usage_seconds_sum{job=~\"ftgo-.*\"}[5m]) / rate(hikaricp_connections_usage_seconds_count{job=~\"ftgo-.*\"}[5m])",
          "legendFormat": "{{ job }} - Avg Usage"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Pending Connection Requests",
      "description": "Number of threads waiting for a connection",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_pending{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Connection Timeout Rate",
      "description": "Rate of connection acquisition timeouts per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_timeout_total{job=~\"ftgo-.*\"}[5m])",
          "legendFormat": "{{ job }} - Timeouts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ftgo", "database", "hikaricp", "connection-pool"],
  "templating": {
    "list": [
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(hikaricp_connections_active{job=~\"ftgo-.*\"}, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "query": "label_values(hikaricp_connections_active{job=~\"ftgo-.*\"}, job)",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FTGO - Database Connection Pool",
  "uid": "ftgo-db-pool",
  "version": 1
}
