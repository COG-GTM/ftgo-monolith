{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FTGO Platform - JVM Metrics (Heap, Garbage Collection, Threads)",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Heap Memory Usage",
      "description": "JVM heap memory used vs. max across services",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Used"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\", job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Non-Heap Memory Usage",
      "description": "JVM non-heap memory (metaspace, code cache, etc.)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\", job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Used"
        },
        {
          "expr": "jvm_memory_committed_bytes{area=\"nonheap\", job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Committed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Heap Usage Percentage",
      "description": "Heap utilization percentage per service. Alert threshold: 85%",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * jvm_memory_used_bytes{area=\"heap\", job=~\"ftgo-.*\"} / jvm_memory_max_bytes{area=\"heap\", job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "GC Pause Duration",
      "description": "Garbage collection pause durations per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"ftgo-.*\"}[5m])",
          "legendFormat": "{{ job }} - {{ action }} ({{ cause }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "GC Collection Count",
      "description": "Rate of garbage collections per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"ftgo-.*\"}[5m])",
          "legendFormat": "{{ job }} - {{ action }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Live Threads",
      "description": "Current thread count per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - Daemon"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Thread States",
      "description": "JVM threads by state per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "targets": [
        {
          "expr": "jvm_threads_states_threads{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }} - {{ state }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Loaded Classes",
      "description": "Number of classes loaded in the JVM",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Process CPU Usage",
      "description": "CPU usage per service process",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Process Uptime",
      "description": "Service uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=~\"ftgo-.*\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ftgo", "jvm", "memory", "gc", "threads"],
  "templating": {
    "list": [
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(up{job=~\"ftgo-.*\"}, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "query": "label_values(up{job=~\"ftgo-.*\"}, job)",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FTGO - JVM Metrics",
  "uid": "ftgo-jvm-metrics",
  "version": 1
}
