      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "targets": [
        {
          "expr": "rate(menus_updated_total{service=\"restaurant-service\"}[5m]) * 60",
          "legendFormat": "Menus Updated"
