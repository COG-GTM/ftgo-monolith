{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FTGO Platform - Business Metrics per Service (Orders, Consumers, Restaurants, Deliveries)",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "--- Order Service ---",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Orders Created (rate/min)",
      "description": "Rate of new orders created per minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "rate(orders_created_total{service=\"order-service\"}[5m]) * 60",
          "legendFormat": "Orders Created"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "Orders Cancelled (rate/min)",
      "description": "Rate of order cancellations per minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "rate(orders_cancelled_total{service=\"order-service\"}[5m]) * 60",
          "legendFormat": "Orders Cancelled"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "title": "Order Value Distribution",
      "description": "Distribution of order monetary values (percentiles)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "orders_total_value{quantile=\"0.5\", service=\"order-service\"}",
          "legendFormat": "P50"
        },
        {
          "expr": "orders_total_value{quantile=\"0.95\", service=\"order-service\"}",
          "legendFormat": "P95"
        },
        {
          "expr": "orders_total_value{quantile=\"0.99\", service=\"order-service\"}",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Orders by State",
      "description": "Current number of orders in each state",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "orders_by_state{service=\"order-service\"}",
          "legendFormat": "{{ state }}"
        }
      ]
    },
    {
      "title": "Order Cancellation Rate (%)",
      "description": "Percentage of orders that are cancelled. Alert threshold: 30%",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "expr": "100 * rate(orders_cancelled_total[15m]) / rate(orders_created_total[15m])",
          "legendFormat": "Cancellation Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "title": "--- Consumer Service ---",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "title": "Consumers Registered (rate/min)",
