      "collapsed": false
    },
    {
      "title": "Deliveries Assigned (rate/min)",
      "description": "Rate of deliveries assigned to couriers per minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "rate(deliveries_assigned_total{service=\"courier-service\"}[5m]) * 60",
