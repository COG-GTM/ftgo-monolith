        {
          "expr": "deliveries_average_time_seconds{quantile=\"0.95\", service=\"courier-service\"}",
          "legendFormat": "P95"
        },
        {
          "expr": "deliveries_average_time_seconds{quantile=\"0.99\", service=\"courier-service\"}",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
