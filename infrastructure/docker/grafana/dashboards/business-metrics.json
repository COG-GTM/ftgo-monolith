      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "targets": [
        {
          "expr": "rate(restaurants_created_total{service=\"restaurant-service\"}[5m]) * 60",
          "legendFormat": "Restaurants Created"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
