        {
          "expr": "rate(consumers_registered_total{service=\"consumer-service\"}[5m]) * 60",
          "legendFormat": "Consumers Registered"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "title": "Consumers Validated (rate/min)",
      "description": "Rate of consumer validations per minute",
      "type": "timeseries",
