  "description": "FTGO Business Metrics — Orders, Consumers, Restaurants, and Deliveries",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 300,
      "title": "Order Service Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "title": "Orders Created (rate)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(orders_created_total{service=\"order-service\"}[5m])", "legendFormat": "Orders Created/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "title": "Orders Cancelled (rate)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(orders_cancelled_total{service=\"order-service\"}[5m])", "legendFormat": "Orders Cancelled/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.3 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "title": "Cancellation Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(orders_cancelled_total{service=\"order-service\"}[5m]) / rate(orders_created_total{service=\"order-service\"}[5m])", "legendFormat": "Cancellation Rate" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "title": "Cumulative Order Value",
      "type": "timeseries",
      "targets": [
        { "expr": "orders_total_value_total{service=\"order-service\"} / 100", "legendFormat": "Total Value (USD)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "title": "Orders by State",
      "type": "timeseries",
      "targets": [
        { "expr": "orders_by_state{service=\"order-service\"}", "legendFormat": "{{ state }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 301,
