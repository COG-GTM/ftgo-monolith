{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FTGO JVM Metrics — Heap, Garbage Collection, and Threads",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Heap Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "title": "Heap Memory Used",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"ftgo-.*\",area=\"heap\"}", "legendFormat": "{{ job }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "title": "Heap Usage Percentage",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"ftgo-.*\",area=\"heap\"} / jvm_memory_max_bytes{job=~\"ftgo-.*\",area=\"heap\"}", "legendFormat": "{{ job }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "title": "Heap Memory by Pool",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"${service}\",area=\"heap\"}", "legendFormat": "{{ job }} — {{ id }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "title": "Non-Heap Memory Used",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"ftgo-.*\",area=\"nonheap\"}", "legendFormat": "{{ job }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 201,
      "title": "Garbage Collection",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 10,
      "title": "GC Pause Time (rate)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"ftgo-.*\"}[5m])", "legendFormat": "{{ job }} — {{ action }} {{ cause }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 11,
      "title": "GC Collection Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_count{job=~\"ftgo-.*\"}[5m])", "legendFormat": "{{ job }} — {{ action }} {{ cause }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 202,
      "title": "Threads",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 20,
      "title": "Live Threads",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_live_threads{job=~\"ftgo-.*\"}", "legendFormat": "{{ job }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 21,
      "title": "Thread States",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_states_threads{job=~\"${service}\"}", "legendFormat": "{{ job }} — {{ state }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 22,
      "title": "Daemon vs Non-Daemon Threads",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_daemon_threads{job=~\"ftgo-.*\"}", "legendFormat": "{{ job }} daemon" },
        { "expr": "jvm_threads_live_threads{job=~\"ftgo-.*\"} - jvm_threads_daemon_threads{job=~\"ftgo-.*\"}", "legendFormat": "{{ job }} non-daemon" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 23,
      "title": "Classes Loaded",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_classes_loaded_classes{job=~\"ftgo-.*\"}", "legendFormat": "{{ job }}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ftgo", "jvm", "memory", "gc", "threads"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "allValue": "ftgo-.*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up{job=~\"ftgo-.*\"}, job)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(up{job=~\"ftgo-.*\"}, job)" },
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FTGO JVM Metrics",
  "uid": "ftgo-jvm-metrics",
  "version": 1
}
